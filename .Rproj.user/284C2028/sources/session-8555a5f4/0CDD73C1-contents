### 4A. Diagnostik Data & Sistem Pakar Rekomendasi

Tujuan: Mendiagnosis kelayakan teknis data dan memberikan argumen bisnis untuk memilih algoritma.

```{r 4a-rekomendasi-model}
# ==============================================================================
# BAGIAN 4A: SISTEM PAKAR REKOMENDASI ALGORITMA
# ==============================================================================

if(!target_col %in% names(df_final)) {
  stop("target_col tidak ditemukan di df_final.")
}

n_rows <- nrow(df_final)

x_data <- df_final %>% select(-all_of(target_col))

prediktor_numerik <- sum(sapply(x_data, is.numeric))
prediktor_kategorik <- sum(sapply(x_data, function(x) {
  is.factor(x) || is.character(x) || is.logical(x)
}))

tabel_target <- table(df_final[[target_col]], useNA = "no")

if(length(tabel_target) < 2) {
  stop("Target hanya memiliki satu kelas. Modeling klasifikasi tidak valid.")
}

proporsi_target <- prop.table(tabel_target)
rasio_imbalance <- max(tabel_target) / min(tabel_target)

status <- ifelse(rasio_imbalance < 2, "Seimbang", "Imbalance")

cat("========================================================\n")
cat(" HASIL DIAGNOSTIK DATA UNTUK MODELING\n")
cat("========================================================\n")
cat(sprintf("Total Observasi : %d Baris\n", n_rows))
cat(sprintf("Fitur/Prediktor : %d Numerik, %d Kategorik\n", 
            prediktor_numerik, prediktor_kategorik))
cat(sprintf("Rasio Target    : 1 : %.1f (%s)\n", 
            rasio_imbalance, status))
cat("--------------------------------------------------------\n")

# 1. SELEKSI TEKNIS
algoritma_lulus <- c("Decision Tree", "Random Forest", "XGBoost")

if(prediktor_kategorik > 0) {
  algoritma_lulus <- c(algoritma_lulus, "Naive Bayes")
}

if(prediktor_numerik > 0) {
  if(n_rows <= 5000) {
    algoritma_lulus <- c(algoritma_lulus, "KNN", "SVM", "FFNN", "RBFNN")
  } else {
    cat("[!] INFO TEKNIS: Data >5000 baris. KNN/SVM/RBFNN berpotensi lebih lambat.\n")
  }
}

if(n_rows >= 5000 && prediktor_numerik > 0) {
  algoritma_lulus <- c(algoritma_lulus, "Deep Learning")
}

cat("\n A. REKOMENDASI TEKNIS (AMAN DIEKSEKUSI)\n")
for(algo in unique(algoritma_lulus)) {
  cat(paste(" -", algo, "\n"))
