### 7E. Imputasi Missing Value

Fungsi chunk ini: mengisi missing value pada data prediksi.

```{r 7e-imputasi-data-prediksi}
# ==============================================================================
# BAGIAN 7E: IMPUTASI MISSING VALUE DATA PREDIKSI
# ==============================================================================

# Fungsi modus untuk data kategorik
modus <- function(x) {
  ux <- na.omit(unique(x))
  ux[which.max(tabulate(match(x, ux)))]
}

for(kolom in names(data_predik_model)) {
  
  if(any(is.na(data_predik_model[[kolom]]))) {
    
    # Jika numerik, isi NA dengan median dari df_final
    if(is.numeric(data_predik_model[[kolom]])) {
      data_predik_model[[kolom]][is.na(data_predik_model[[kolom]])] <- 
        median(df_final[[kolom]], na.rm = TRUE)
    }
    
    # Jika factor/kategorik, isi NA dengan modus dari df_final
    if(is.factor(data_predik_model[[kolom]])) {
      nilai_modus <- modus(df_final[[kolom]])
      
      data_predik_model[[kolom]][is.na(data_predik_model[[kolom]])] <- 
        as.character(nilai_modus)
      
      data_predik_model[[kolom]] <- factor(
        data_predik_model[[kolom]],
        levels = levels(df_final[[kolom]])
      )
    }
  }
}

cat("--- CEK MISSING VALUE SETELAH IMPUTASI ---\n")
print(colSums(is.na(data_predik_model)))

cat("\n--- STRUKTUR FINAL DATA PREDIKSI ---\n")
str(data_predik_model)
```

