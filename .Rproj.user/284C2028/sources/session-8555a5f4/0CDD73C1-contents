#   size = rasio_split * nrow(df_final)
# )
# 
# data_train <- df_final[index_train, ]
# data_test  <- df_final[-index_train, ]


# ==============================================================================
# PILIHAN 2: STRATIFIED SPLIT
# Dipakai untuk klasifikasi agar proporsi kelas target di train dan test tetap seimbang
# Cocok untuk kasus Status = Y / N
# ==============================================================================

index_train <- createDataPartition(
  y = df_final[[target_col]], 
  p = rasio_split, 
  list = FALSE
)

data_train <- df_final[index_train, ]
data_test  <- df_final[-index_train, ]


# ==============================================================================
# PILIHAN 3: TIME-BASED SPLIT
# Dipakai jika data memiliki kolom waktu/tanggal
# Data lama untuk training, data terbaru untuk testing
# ==============================================================================

# date_col <- "Tanggal" # Ganti sesuai nama kolom tanggal
# 
# df_final <- df_final[order(df_final[[date_col]]), ]
# 
# batas <- floor(rasio_split * nrow(df_final))
# 
# data_train <- df_final[1:batas, ]
# data_test  <- df_final[(batas + 1):nrow(df_final), ]


# ==============================================================================
# CEK DIMENSI DATA
# ==============================================================================
cat(sprintf("Dimensi Train : %d baris\nDimensi Test  : %d baris\n", 
            nrow(data_train), nrow(data_test)))


# ==============================================================================
# TRAIN CONTROL UNTUK CROSS VALIDATION
# ==============================================================================

# Otomatis deteksi fungsi summary: Binary vs Multiclass
if(length(levels(df_final[[target_col]])) == 2) {
  fungsi_summary <- twoClassSummary   
} else {
  fungsi_summary <- multiClassSummary 
}

ctrl <- trainControl(
  method = "cv", 
  number = 5,
  classProbs = TRUE, 
  summaryFunction = fungsi_summary
  # sampling = "up" # UNCOMMENT jika data imbalance dan ingin ditangani otomatis
)
```

Dataset dibagi menjadi Data Latih dan Data Uji dengan rasio [...misal: 80:20...] menggunakan metode [...Stratified Split...].

Selanjutnya, proses pelatihan model dilakukan menggunakan [...misal: 5...]-fold Cross-Validation. Teknik ini membagi data latih menjadi 5 bagian secara bergantian untuk proses training dan validasi, sehingga performa model dapat dievaluasi dengan lebih stabil, objektif, dan mengurangi risiko overfitting.

