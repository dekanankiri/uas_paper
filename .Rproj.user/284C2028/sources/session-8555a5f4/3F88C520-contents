```{r master-recipe}
master_recipe <- recipe(
  formula = as.formula(paste(TARGET_VAR, "~ .")),
  data = data_train
) %>%
  step_novel(all_nominal_predictors(), new_level = "unseen") %>%
  
  # PERBAIKAN: Ubah nama default penampung kategori langka agar tidak bentrok
  step_other(all_nominal_predictors(), threshold = 0.05, other = "other_infrequent") %>%
  
  step_impute_median(all_numeric_predictors()) %>%
  step_impute_mode(all_nominal_predictors()) %>%
  step_ordinalscore(all_ordered_predictors()) %>%
  step_dummy(all_nominal_predictors(), one_hot = FALSE) %>%
  
  step_zv(all_predictors()) %>%
  {
    if (USE_SMOTE) {
      step_smote(., !!sym(TARGET_VAR), over_ratio = 1, seed = SEED_NUMBER)
    } else {
      .
    }
  } %>%
  step_normalize(all_numeric_predictors()) %>%
  step_corr(all_numeric_predictors(), threshold = 0.9) %>%
  step_nzv(all_predictors())

cat("\n========== MASTER RECIPE BERHASIL DIBUAT ==========\n")
print(master_recipe)

cat("\n========== PREVIEW DATA SETELAH PREPROCESSING ==========\n")
