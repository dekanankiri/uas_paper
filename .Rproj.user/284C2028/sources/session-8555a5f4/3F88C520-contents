```{r eda-correlation, fig.height=8, fig.width=10}
# ========== Visualisasi Korelasi & Distribusi ==========
# Dosen sering menilai kemampuan EDA sebelum modeling!

cat("\n========== EXPLORATORY DATA ANALYSIS ==========\n")

# 1. Proteksi untuk Correlation Plot (Batasi maks 5 numerik agar tidak crash)
numeric_vars <- data_clean %>% select(where(is.numeric)) %>% names()

if (length(numeric_vars) > 0) {
  # Ambil maksimal 5 variabel numerik pertama
  vars_to_plot <- numeric_vars[1:min(5, length(numeric_vars))]
  
  # Siapkan data: pilih kolom, buang baris ber-NA khusus untuk plot agar korelasi tidak error
  plot_data_num <- data_clean %>%
    select(all_of(vars_to_plot), all_of(TARGET_VAR)) %>%
    drop_na()
  
  if (nrow(plot_data_num) > 10) {
    # PERBAIKAN: Gunakan .data[[TARGET_VAR]] alih-alih !!sym() agar ggpairs tidak error
    p_cor <- plot_data_num %>%
      sample_n(min(nrow(.), 500)) %>%
      ggpairs(
        mapping = aes(color = .data[[TARGET_VAR]], alpha = 0.5),
        upper = list(continuous = wrap("cor", size = 3)),
        lower = list(continuous = wrap("points", alpha = 0.3)),
        diag = list(continuous = wrap("densityDiag", alpha = 0.5))
      ) +
      labs(title = "Pairwise Correlation (Top 5 Numeric Features)") +
      theme_minimal()
    
    print(p_cor)
  } else {
    cat("ℹ INFO: Data bersih terlalu sedikit untuk membuat correlation plot.\n")
  }
} else {
  cat("ℹ INFO: Tidak cukup variabel numerik untuk correlation plot.\n")
}

# 2. Visualisasi distribusi kategori vs target
categorical_cols <- data_clean %>%
  select(where(is.factor), -all_of(TARGET_VAR))

if (ncol(categorical_cols) > 0) {
  # Ambil maksimal 4 kolom kategori pertama
  cat_to_plot <- names(categorical_cols)[1:min(4, ncol(categorical_cols))]
  
  plot_list <- map(cat_to_plot, function(var) {
    data_clean %>%
      drop_na(all_of(c(var, TARGET_VAR))) %>% # Buang NA agar grafik bar rapi
      count(.data[[var]], .data[[TARGET_VAR]]) %>%
      ggplot(aes(x = .data[[var]], y = n, fill = .data[[TARGET_VAR]])) +
      geom_col(position = "dodge") +
      labs(title = paste("Distribution of", var), x = NULL, y = "Count") +
      theme_minimal() +
      theme(axis.text.x = element_text(angle = 45, hjust = 1))
  })
  
  # Kombinasi plot dengan patchwork
  print(wrap_plots(plot_list, ncol = 2) + plot_annotation(title = "Categorical Variables vs Target"))
}
```

