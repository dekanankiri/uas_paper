#   step_normalize(all_numeric_predictors()) %>%  # WAJIB sebelum PCA!
#   step_pca(all_numeric_predictors(), threshold = 0.95) %>%  # Reduksi dimensi
#   step_dummy(all_nominal_predictors()) %>%
#   step_nzv(all_predictors())
#
# KASUS 3: Data imbalanced parah + high cardinality categorical
# recipe(...) %>%
#   step_novel(all_nominal_predictors()) %>%
#   step_other(all_nominal_predictors(), threshold = 0.03) %>%
#   step_impute_bag(all_numeric_predictors()) %>%
