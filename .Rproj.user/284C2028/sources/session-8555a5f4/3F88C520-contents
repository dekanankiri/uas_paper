# TAHAP 2: INGESTION & PEMBERSIHAN DATA

# ============================================================================

```{r pembersihan-data}
# ============================================================================
# TAHAP 2: PEMBERSIHAN DATA & PENCEGAHAN LEAKAGE
# ============================================================================

# --- 1. STANDARDISASI NAMA KOLOM ---
# Menyamakan format nama target dan seluruh kolom menjadi huruf kecil (snake_case)
TARGET_VAR <- janitor::make_clean_names(TARGET_VAR)
data_clean <- DATA_INPUT %>% clean_names()

# --- 2. PENCEGAHAN DATA LEAKAGE (HAPUS KOLOM BOCOR) ---
# Tuliskan kolom yang tidak logis untuk prediksi (misal: ID, Tanggal, atau variabel Survival)
# Hapus isi c() menjadi kosong jika tidak ada kolom yang perlu dibuang: c()
kolom_bocor <- c("statusdelirium", "timedelirium", "time", "tgldelir", "tglmask", "tglplg")

data_clean <- data_clean %>%
  select(-any_of(kolom_bocor))

# --- 3. PENANGANAN FORMAT STRING & KEKOSONGAN (NA) ---
convert_to_na <- function(x) {
  if (is.character(x)) {
    x[x %in% c("", " ", "-", "NA", "na", "N/A", "n/a", "null", "NULL", "?")] <- NA
  }
  return(x)
}

data_clean <- data_clean %>%
  mutate(across(everything(), convert_to_na)) %>%
  mutate(across(where(is.character), as.factor)) %>%
  mutate(!!sym(TARGET_VAR) := factor(!!sym(TARGET_VAR)))

# --- 4. HAPUS BARIS JIKA TARGET VARIABEL KOSONG (NA) ---
# Mesin tidak bisa belajar dari data yang kunci jawabannya (target) tidak ada
if (any(is.na(data_clean[[TARGET_VAR]]))) {
  cat("⚠️ WARNING: Target variable memiliki NA! Menghapus baris dengan NA...\n")
  data_clean <- data_clean %>% filter(!is.na(!!sym(TARGET_VAR)))
}

# --- 5. INSPEKSI & DIAGNOSTIK PRE-MODELING ---
cat("\n========== STRUKTUR DATA SETELAH PEMBERSIHAN ==========\n")
glimpse(data_clean)

cat("\n========== MISSING VALUE PER KOLOM ==========\n")
missing_summary <- data_clean %>%
  summarise(across(everything(), ~sum(is.na(.)))) %>%
  pivot_longer(everything(), names_to = "Variable", values_to = "Missing_Count") %>%
  filter(Missing_Count > 0)

if (nrow(missing_summary) > 0) {
  print(missing_summary)
} else {
  cat("Tidak ada missing value!\n")
}

cat("\n========== DISTRIBUSI TARGET VARIABLE ==========\n")
target_dist <- data_clean %>%
  count(!!sym(TARGET_VAR)) %>%
  mutate(Proportion = n / sum(n))
print(target_dist)

if (nrow(target_dist) == 2) {
  imbalance_ratio <- max(target_dist$n) / min(target_dist$n)
  cat("\nImbalance Ratio:", round(imbalance_ratio, 2), ":1\n")
  if (imbalance_ratio > 2) {
    cat("⚠️ Data imbalanced terdeteksi! Pertimbangkan USE_SMOTE = TRUE\n")
  }
}
```

Struktur *chunk* `TAHAP 2` ini telah dirombak total menjadi 5
sub-tahapan yang sangat berurutan. Format ini dirancang khusus agar saat
menghadapi ujian praktik nanti, Anda tidak perlu memburu baris kode yang
tersebar. Cukup fokus pada **Bagian 2 (Pencegahan Data Leakage)** jika
ada variabel yang perlu dibuang.

Ganti seluruh *chunk* `# TAHAP 2: INGESTION & PEMBERSIHAN DATA` Anda
dengan susunan di bawah ini:

