```{r helper-tuning-function}
tune_model <- function(model_spec, model_name, param_ranges) {
  cat("\n========== TUNING", toupper(model_name), "==========\n")
  
  wf <- workflow() %>%
    add_recipe(master_recipe) %>%
    add_model(model_spec)
  
  # PERBAIKAN: Gunakan do.call alih-alih !!! untuk mencegah error lingkungan R
  if (TUNING_STRATEGY == "latin") {
    grid <- do.call(grid_latin_hypercube, c(param_ranges, list(size = GRID_SIZE)))
  } else {
    grid <- do.call(grid_regular, c(param_ranges, list(levels = GRID_SIZE)))
  }
  
  set.seed(SEED_NUMBER)
  tune_results <- wf %>%
    tune_grid(
      resamples = data_folds,
      grid = grid,
      metrics = classification_metrics,
      control = control_grid(save_pred = TRUE, verbose = FALSE)
    )
  
  cat("✓", model_name, "tuning selesai!\n")
  return(list(workflow = wf, results = tune_results))
}
```

