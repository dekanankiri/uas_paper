```{r cheat-sheet-preprocessing, eval=FALSE}
# ============================================================================
# PANDUAN PREPROCESSING ALTERNATIF - PILIH SESUAI SOAL UJIAN
# ============================================================================
#
# BAGIAN INI ADALAH REFERENSI! Set eval=FALSE agar tidak dieksekusi.
# Copy-paste fungsi yang dibutuhkan ke master_recipe di bawah.
#
# ============================================================================
# A. ALTERNATIF IMPUTASI MISSING VALUE
# ============================================================================
#
# 1. KNN IMPUTATION (untuk data dengan pola missing yang kompleks)
#    → Mengisi NA berdasarkan K-tetangga terdekat
#    → Baik untuk data dengan korelasi antar variabel
#
#    step_impute_knn(all_predictors(), neighbors = 5)
#
# 2. BAGGING IMPUTATION (untuk data dengan missing banyak)
#    → Menggunakan decision tree ensemble untuk prediksi nilai missing
#    → Lebih akurat tapi lebih lambat
#
#    step_impute_bag(all_numeric_predictors(), trees = 25, seed = 123)
#
# 3. LINEAR IMPUTATION (untuk data dengan hubungan linear kuat)
#    → Menggunakan regresi linear untuk prediksi missing value
#    → Cepat dan efisien untuk data terstruktur
#
#    step_impute_linear(all_numeric_predictors(), 
#                       impute_with = imp_vars(all_numeric_predictors()))
#
# 4. MEAN/MODE (default - paling cepat)
#    step_impute_mean(all_numeric_predictors())
#    step_impute_mode(all_nominal_predictors())
#
# ============================================================================
# B. PENANGANAN OUTLIER & SKEWNESS
# ============================================================================
#
# 1. YEO-JOHNSON TRANSFORMATION
#    → Menangani distribusi skewed (miring) dan outlier
#    → Lebih fleksibel dari Box-Cox (bisa untuk nilai negatif)
#    → WAJIB sebelum normalisasi jika data sangat skewed!
#
#    step_YeoJohnson(all_numeric_predictors())
#
# 2. SPATIAL SIGN TRANSFORMATION
#    → Menangani outlier ekstrem dengan proyeksi ke unit hypersphere
#    → Baik untuk KNN dan SVM yang sensitif outlier
#    → Gunakan SETELAH normalisasi
#
#    step_normalize(all_numeric_predictors())
#    step_spatialsign(all_numeric_predictors())
#
# 3. WINSORIZATION (capping outlier)
#    → Batasi nilai ekstrem ke persentil tertentu
#    
#    step_mutate_at(
#      all_numeric_predictors(),
#      fn = ~ case_when(
#        . > quantile(., 0.99, na.rm = TRUE) ~ quantile(., 0.99, na.rm = TRUE),
#        . < quantile(., 0.01, na.rm = TRUE) ~ quantile(., 0.01, na.rm = TRUE),
#        TRUE ~ .
#      )
#    )
#
# ============================================================================
# C. REDUKSI DIMENSI (jika fitur > 50 atau waktu training lama)
# ============================================================================
#
# 1. PRINCIPAL COMPONENT ANALYSIS (PCA)
#    → Mengurangi dimensi dengan mempertahankan varians maksimal
#    → WAJIB dilakukan SETELAH normalisasi!
#    → Threshold 0.95 = pertahankan 95% varians
#
#    step_normalize(all_numeric_predictors())  # WAJIB sebelum PCA!
#    step_pca(all_numeric_predictors(), threshold = 0.95)
#
# 2. PCA dengan jumlah komponen fixed
#    step_pca(all_numeric_predictors(), num_comp = 10)
#
# ============================================================================
# D. PENANGANAN IMBALANCED DATA (selain SMOTE)
# ============================================================================
#
# 1. ROSE (Random Over-Sampling Examples)
#    → Sintetik oversampling berbasis kernel density
#    
#    step_rose(!!sym(TARGET_VAR), over_ratio = 1, seed = 123)
#
# 2. DOWNSAMPLING (hapus kelas mayoritas)
#    → Cepat tapi mengurangi data
#    
#    step_downsample(!!sym(TARGET_VAR), under_ratio = 1, seed = 123)
#
# 3. UPSAMPLE (duplikasi kelas minoritas)
#    → Sederhana tapi risiko overfitting
#    
#    step_upsample(!!sym(TARGET_VAR), over_ratio = 1, seed = 123)
#
# ============================================================================
# E. TRANSFORMASI KATEGORI LANJUTAN
# ============================================================================
#
# 1. TARGET ENCODING (encode kategori berdasarkan rata-rata target)
#    → Baik untuk high cardinality categorical
#    
