#      fn = ~ as.numeric(fct_infreq(.))
#    )
#
# ============================================================================
# F. CONTOH URUTAN RECIPE KHUSUS
# ============================================================================
#
# KASUS 1: Data dengan banyak outlier + skewed distribution
# recipe(...) %>%
#   step_impute_knn(all_predictors(), neighbors = 5) %>%
#   step_YeoJohnson(all_numeric_predictors()) %>%  # Tangani skewness
#   step_normalize(all_numeric_predictors()) %>%
#   step_spatialsign(all_numeric_predictors()) %>%  # Tangani outlier
