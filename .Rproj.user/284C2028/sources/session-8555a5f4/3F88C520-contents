# TAHAP 3: DATA SPLITTING & RESAMPLING

# ============================================================================

```{r data-splitting}
set.seed(SEED_NUMBER)
data_split <- initial_split(
  data_clean,
  prop = TRAIN_PROPORTION,
  strata = !!sym(TARGET_VAR)
)

data_train <- training(data_split)
data_test <- testing(data_split)

cat("\n========== RINGKASAN DATA SPLITTING ==========\n")
cat("Total data:", nrow(data_clean), "\n")
cat("Data training:", nrow(data_train), "(",
    round(nrow(data_train)/nrow(data_clean)*100, 1), "%)\n")
cat("Data testing:", nrow(data_test), "(",
    round(nrow(data_test)/nrow(data_clean)*100, 1), "%)\n")

# ========== Cross-Validation Folds untuk Tuning ==========
# Cek apakah jumlah baris cukup untuk CV_FOLDS
actual_n_train <- nrow(data_train)

if (actual_n_train <= CV_FOLDS) {
  CV_FOLDS_ADJUSTED <- 2 # Minimal 2 fold jika data sangat sedikit
  cat("⚠️ INFO: Data training (", actual_n_train, " baris) terlalu sedikit.\n")
  cat("CV_FOLDS disesuaikan otomatis menjadi:", CV_FOLDS_ADJUSTED, "folds.\n")
} else {
  CV_FOLDS_ADJUSTED <- CV_FOLDS
}

set.seed(SEED_NUMBER)
data_folds <- vfold_cv(
  data_train,
  v = CV_FOLDS_ADJUSTED,
  strata = !!sym(TARGET_VAR)
)

cat("\nCross-validation:", CV_FOLDS_ADJUSTED, "folds\n")

cat("\n========== PROPORSI KELAS DI TRAINING SET ==========\n")
data_train %>%
  count(!!sym(TARGET_VAR)) %>%
  mutate(Proportion = n / sum(n)) %>%
  print()
```

